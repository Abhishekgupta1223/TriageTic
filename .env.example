# Copy this file to .env and fill in your values.
# The real .env is gitignored — never commit your actual API key.
#
# Usage:
#   cp .env.example .env
#   # then edit .env and paste your key

# Required: Anthropic API key. Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Optional: override the default model
# ANTHROPIC_MODEL=claude-haiku-4-5

# Optional: override the confidence threshold for routing
# CONFIDENCE_THRESHOLD=0.65
